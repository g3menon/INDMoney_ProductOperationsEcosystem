Frontend
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

Backend
APP_ENV=development
LOG_LEVEL=debug

API_BASE_URL=
# Comma-separated origins are supported for local dev, e.g. http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=

# Set to true only for offline/local scaffolding when Supabase is intentionally unavailable.
PHASE1_SKIP_SUPABASE_STARTUP_CHECK=false

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Phase 3: Chat storage ──────────────────────────────────────────────────────
# Controls where chat session and message state is persisted.
# - memory  (default) — in-process only; resets on restart. Use for local dev.
# - supabase          — persists to Supabase (requires phase3_chat_schema.sql applied).
# Optional — defaults to memory if unset.
CHAT_STORAGE_MODE=memory

GEMINI_API_KEY=
GEMINI_API_KEY_FALLBACK=
# Default synthesis model (Gemini API). Override only after compatibility checks.
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_API_KEY_FALLBACK=

# Max segments sent to Groq for theme generation (Groq TPM guardrail).
# Groq free tier is ~6000 TPM. 60 segments x 800 chars ≈ 3900 tokens.
# Do NOT increase above 80 on free tier.
# This does NOT limit how many reviews are collected or stored.
PULSE_MAX_THEME_SEGMENTS=60

# LLM guardrails (Phase 4)
# Cache LLM responses in-memory (per-process). Disable with LLM_CACHE_ENABLED=false.
LLM_CACHE_ENABLED=true
# Cap number of retrieved RAG chunks sent to the LLM prompt.
MAX_RAG_CHUNKS_FOR_LLM=3

# Model tier routing (Guardrail 4)
# Light + standard tiers default to Groq; heavy tier reserved for Gemini.
LLM_LIGHT_MODEL=llama-3.3-70b-versatile
LLM_STANDARD_MODEL=llama-3.3-70b-versatile
LLM_HEAVY_MODEL=gemini-2.5-flash
LLM_PRIMARY_PROVIDER=groq

# Script throttling (Guardrail 3)
GEMINI_RPM_LIMIT=8   # free tier: 10 RPM max, use 8 for safety margin
GROQ_RPM_LIMIT=25    # free tier: 30 RPM max, use 25 for safety margin

GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/calendar.events,https://www.googleapis.com/auth/spreadsheets
GOOGLE_AUTHORIZED_EMAIL=
GMAIL_SENDER_EMAIL=
GOOGLE_CALENDAR_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=

# Fernet symmetric key for encrypting stored OAuth tokens at rest (Rules D7).
# Must be a valid base64-encoded 32-byte key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
SCHEDULER_SHARED_SECRET=

# ── Phase 7: Google OAuth bootstrap token (env-var fallback) ─────────────────
# Set to a pre-authorized refresh token for local dev / Phase 7 testing when
# the full Google OAuth login flow (Phase 8) has not yet been run.
#
# How to obtain one manually:
#   1. In Google Cloud Console → OAuth 2.0 clients → your web app client.
#   2. Use the OAuth Playground (https://developers.google.com/oauthplayground)
#      or run the one-off script:
#        python scripts/fetch_google_refresh_token.py
#      (see Docs/Runbook.md → "Google OAuth bootstrap" for the full procedure).
#   3. Paste the refresh token value here.
#
# Required scopes for Phase 7:
#   gmail.send  |  calendar.events  |  spreadsheets
# (see GOOGLE_OAUTH_SCOPES above for the full scope string)
#
# TODO Phase 8: remove this variable once the full OAuth flow stores tokens in
#               the google_oauth_tokens table.
GOOGLE_OAUTH_REFRESH_TOKEN=

DEFAULT_TIMEZONE=Asia/Kolkata

# ── Phase 5: Booking storage ──────────────────────────────────────────────────
# Controls where booking state is persisted.
# - memory  (default) — in-process only; resets on restart. Use for local dev.
# - supabase          — persists to Supabase (requires phase5_schema.sql applied).
# Optional — defaults to memory if unset.
BOOKING_STORAGE_MODE=memory

